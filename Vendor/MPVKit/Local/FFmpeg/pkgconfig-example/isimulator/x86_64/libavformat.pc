prefix=/path/to/workdir/FFmpeg/isimulator/thin/x86_64
exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/isimulator/thin/x86_64/lib
includedir=/path/to/workdir/FFmpeg/isimulator/thin/x86_64/include

Name: libavformat
Description: FFmpeg container format library
Version: 62.3.100
Requires: libavcodec >= 62.11.100, libswresample >= 6.1.100, libavutil >= 60.8.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavformat -lm -lxml2 -lz -lpthread -licucore -lm -lgmp -lz -L/path/to/workdir/gnutls/isimulator/thin/x86_64/lib -lgnutls -framework Security -framework CoreFoundation -L/path/to/workdir/nettle/isimulator/thin/x86_64/lib -lhogweed -lgmp -lnettle
Libs.private: 
Cflags: -I${includedir}
