prefix=/path/to/workdir/FFmpeg/isimulator/thin/x86_64
exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/isimulator/thin/x86_64/lib
includedir=/path/to/workdir/FFmpeg/isimulator/thin/x86_64/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 62.1.100
Requires: libavformat >= 62.3.100, libavcodec >= 62.11.100, libswresample >= 6.1.100, libavutil >= 60.8.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavdevice -lm
Libs.private: 
Cflags: -I${includedir}
