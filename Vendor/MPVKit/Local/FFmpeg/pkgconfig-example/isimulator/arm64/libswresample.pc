prefix=/path/to/workdir/FFmpeg/isimulator/thin/arm64
exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/isimulator/thin/arm64/lib
includedir=/path/to/workdir/FFmpeg/isimulator/thin/arm64/include

Name: libswresample
Description: FFmpeg audio resampling library
Version: 6.1.100
Requires: libavutil >= 60.8.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lswresample -lm
Libs.private: 
Cflags: -I${includedir}
