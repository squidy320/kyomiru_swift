prefix=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64
exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64/lib
includedir=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64/include

Name: libavcodec
Description: FFmpeg codec library
Version: 62.11.100
Requires: libswresample >= 6.1.100, libavutil >= 60.8.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavcodec -L/path/to/workdir/lcms2/maccatalyst/thin/arm64/lib -llcms2 -lm -lm -L/path/to/workdir/libdav1d/maccatalyst/thin/arm64/lib -ldav1d -framework AudioToolbox -pthread -L/path/to/workdir/libshaderc/maccatalyst/thin/arm64/lib -lshaderc_combined -lz -framework VideoToolbox -framework CoreFoundation -framework CoreMedia -framework CoreVideo
Libs.private: 
Cflags: -I${includedir}
