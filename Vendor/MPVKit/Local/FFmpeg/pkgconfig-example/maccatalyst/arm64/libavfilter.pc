prefix=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64
exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64/lib
includedir=/path/to/workdir/FFmpeg/maccatalyst/thin/arm64/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 11.4.100
Requires: libswscale >= 9.1.100, libavformat >= 62.3.100, libavcodec >= 62.11.100, libswresample >= 6.1.100, libavutil >= 60.8.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavfilter -pthread -lm -L/path/to/workdir/libplacebo/maccatalyst/thin/arm64/lib -lplacebo -ldl -L/path/to/workdir/libshaderc/maccatalyst/thin/arm64/lib -lshaderc_combined -L/path/to/workdir/vulkan/maccatalyst/thin/arm64/lib -lMoltenVK -framework CoreFoundation -framework CoreGraphics -framework Foundation -framework IOSurface -framework Metal -framework QuartzCore -framework UIKit -framework IOKit -L/path/to/workdir/lcms2/maccatalyst/thin/arm64/lib -llcms2 -lm -L/path/to/workdir/libdovi/maccatalyst/thin/arm64/lib -ldovi -liconv -lSystem -lc -lm -L/path/to/workdir/libass/maccatalyst/thin/arm64/lib -lass -liconv -framework ApplicationServices -framework CoreFoundation -L/path/to/workdir/libfreetype/maccatalyst/thin/arm64/lib -lfreetype -lz -L/path/to/workdir/libfribidi/maccatalyst/thin/arm64/lib -lfribidi -L/path/to/workdir/libharfbuzz/maccatalyst/thin/arm64/lib -lharfbuzz -lm -L/path/to/workdir/libunibreak/maccatalyst/thin/arm64/lib -lunibreak -L/path/to/workdir/libshaderc/maccatalyst/thin/arm64/lib -lshaderc_combined
Libs.private: 
Cflags: -I${includedir}
