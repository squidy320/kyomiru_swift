exec_prefix=${prefix}
libdir=/path/to/workdir/FFmpeg/ios/thin/arm64/lib
includedir=/path/to/workdir/FFmpeg/ios/thin/arm64/include

Name: libswscale
Description: FFmpeg image rescaling library
Version: 9.1.100
Requires: libavutil >= 60.8.100
